{
  "manifest_version": 3,
  "name": "AI Studio Automation",
  "version": "1.0.0",
  "description": "Batch auto-submit prompts on Google AI Studio - No API Key needed",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Studio Automation"
  },
  "content_scripts": [
    {
      "matches": ["https://aistudio.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
